Script Caboom#0#1
(
  if
  (
    Any( i , Green , IsLess( DistanceUnitUnit( i , GetUnitOfPlayer( 0, 0 ) ) , 2 ) )
  )
  then
  (
    KillScript(  )
    For( VSS#i#val, Green ) 
    (
      Caboom#0#2( VSS#i#val )
    )
    Caboom#0#3( this ) 
  )
)

