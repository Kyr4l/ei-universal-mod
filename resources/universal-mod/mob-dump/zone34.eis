Script CheckFail
(
  if
  (
    Not( Every( i, Heroes, IsAlive( i ) ) )
  )
  then
  (
    KillScript(  )
    EndOfGame( this )
  )
)

Script EndOfGame
(
  if
  (
  )
  then
  (
    KillScript(  )
    UMSentry( GetUnitOfPlayer( 0, 0 ), 1, 1 )
    RemoveUnitFromServer( GetUnitOfPlayer( 0, 0 ) )
    Sleep( 15 )
    GameOver()
  )
)

Script VCheck#0#1
(
