Script #z35q1Start
(
  if
  (
  )
  then
  (
    KillScript(  ) 
    QStart( "z35q1" )
    RemoveUnitFromServer( GetObjectByID( "44432400" ) )
    RemoveUnitFromServer( GetObjectByID( "44432401" ) )
    RemoveUnitFromServer( GetObjectByID( "44432402" ) )
    RemoveUnitFromServer( GetObjectByID( "44432403" ) )
    Sleep( 2 )
    AddMob( "z35q1_strongwarriors.mob" )
    Sleep( 250 )
    For( i, LeftUp1 ) (
      Run( i )
      UMGuard( i, 87, 277, 7 )
    )
    ConsoleString( "#z35q1Start" )
  )
)

