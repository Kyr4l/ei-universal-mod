Script #GoInside#1
(
  if
  (
    IsLess( DistanceUnitPoint( this, 87, 277 ), 7 )
  )
  then
  (
    KillScript(  ) 
    UMGuard( this, 262, 222, 7 )
    //ConsoleString( "#GoInside#1 a" )
  )
  if
  (
    IsLess( DistanceUnitPoint( this, 301, 310 ), 7 )
  )
  then
  (
    KillScript(  ) 
    UMGuard( this, 262, 222, 7 )
    //ConsoleString( "#GoInside#1 b" )
  )
  if
  (
    IsLess( DistanceUnitPoint( this, 367, 210 ), 7 )
  )
  then
  (
    KillScript(  ) 
    UMGuard( this, 262, 222, 7 )
    //ConsoleString( "#GoInside#1 c" )
  )
  if
  (
    IsLess( DistanceUnitPoint( this, 21, 225 ), 7 )
  )
  then
  (
    KillScript(  ) 
    UMGuard( this, 262, 222, 7 )
    //ConsoleString( "#GoInside#1 d" )
  )
)

