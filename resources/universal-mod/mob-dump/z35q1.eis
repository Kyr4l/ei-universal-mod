Script #Fail
(
  if
  (
    Any( i, GetPlayerUnits( 1 ), IsDead( i ) )
  )
  then
  (
    KillScript(  ) 
    GSSetVar( 0, "q.z35q1.z35q1.1", 3 )
    GSSetVar( 0, "q.z35q1.z35q1", 3 )
  )
  if
  (
    Any( i, GetPlayerUnits( 2 ), IsDead( i ) )
  )
  then
  (
    KillScript(  ) 
    GSSetVar( 0, "q.z35q1.z35q1.1", 3 )
    GSSetVar( 0, "q.z35q1.z35q1", 3 )
  )
)

Script #Complete
(
  if
  (
    IsEqual( GSGetVar( 0, "q.z35q1.z35q1.2" ), 2 )
    IsEqual( GSGetVar( 0, "q.z35q1.z35q1.3" ), 2 )
    IsEqual( GSGetVar( 0, "q.z35q1.z35q1.4" ), 2 )
    Not( IsEqual( GSGetVar( 0, "q.z35q1.z35q1" ), 3 ) )
  )
  then
  (
    KillScript(  ) 
    GSSetVar( 0, "q.z35q1.z35q1.1", 2 )
    GSSetVar( 0, "q.z35q1.z35q1", 2 )
    QuestComplete( 0, "q.z35q1" )
    //QFinish(  )
  )
)

Script #Victory#0
(
  if
  (
    GSGetVar( 0, "q.z35q1.z35q1.4" )
    Every( k, Left1, Not( IsAlive( k ) ) )
  )
  then
  (
    KillScript(  ) 
    GSSetVar( 0, "q.z35q1.z35q1.4", 2 )
  )
)

Script #Victory#1
(
  if
  (
    GSGetVar( 0, "q.z35q1.z35q1.3" )
    Every( k, Right1, Not( IsAlive( k ) ) )
    Every( k, Right2, Not( IsAlive( k ) ) )
    Every( k, Right3, Not( IsAlive( k ) ) )
    Every( k, Right4, Not( IsAlive( k ) ) )
    Every( k, Right5, Not( IsAlive( k ) ) )
    GSGetVar( 0, "z35q1.crap1o" )
  )
  then
  (
    KillScript(  ) 
    GSSetVar( 0, "q.z35q1.z35q1.3", 2 )
  )
)

