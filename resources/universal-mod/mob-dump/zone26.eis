Script VCheck#0#5
(
  if
  (
    Any( i, Heroes, IsInArea( 1, GetX( i ) , GetY( i )  )  )
    IsEqual( GetLeverState( GetObject( 43974 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "q.gz26k.q21k.4", 2 )
    GSSetVarMax( 0, "q.gz26k.q21k", 2 )
    DeleteArea( 1 )
    QuestComplete( 0, "q21k" )
    LeaveToZone( 0, "cz4k", 0 )
  )
)

Script VCheck#0#6
(
