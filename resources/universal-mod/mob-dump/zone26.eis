  )
  then
  (
    KillScript(  )
    SwitchLeverState( GetObject( 4555 ) , 1 )
  )
)

Script Barell#1
(
  if
  (
    IsEqual( GetLeverState( GetObject( 2223991 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    GiveItem( 0 , "material.steel[1]" )
    Sleep( 40 )
    SwitchLeverState( GetObject( 2223991 ) , 0 )
  )
)

