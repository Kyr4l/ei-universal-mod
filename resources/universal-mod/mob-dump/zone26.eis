Script VCheck#0#1
(
  if
  (
    IsEqual( GSGetVar( 0, "q.gz26k.q21k" ) , 1 )
  )
  then
  (
    KillScript(  )
    AddRoundToArea( 1, 67, 163, 7 )
    Sleep( 20 )
    GSSetVarMax( 0, "q.gz26k.q21k.1", 1 )
    CreateFX( GetX( GetUnitOfPlayer( 0 , 0 ) ) , GetY( GetUnitOfPlayer( 0 , 0 ) ) , GetZ( GetUnitOfPlayer( 0 , 0 ) ) , 15, 50, "Acks\Scenario\17.wav" )
  )
)

Script VCheck#0#2
(
  if
  (
    IsEqual( GetLeverState( GetObject( 1021003 ) ) , 1 )
    IsEqual( GSGetVar( 0, "q.gz26k.q21k.1" ) , 1 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "q.gz26k.q21k.1", 2 )
    GSSetVarMax( 0, "q.gz26k.q21k.2", 1 )
    GiveQuestItem( 0, "KKey05" )
  )
)

