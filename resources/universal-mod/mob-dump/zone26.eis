DeclareScript #OnBriefingComplete (  nPlayer : float,  szComplete : string )

Script Start
(
  if
  (
    IsEqual( GSGetVar( 0, "start_zone26" ) , 0 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "start_zone26", 1 )
    GSSetVarMax( 0, "q.gz26k.q21k", 1 )
    Sleep( 5 )
  )
)

Script CheckFail
(
  if
  (
    Not( Every( i, Heroes, IsAlive( i ) ) )
  )
  then
  (
    KillScript(  )
    EndOfGame( this )
  )
)

Script EndOfGame
(
  if
  (
  )
  then
  (
    KillScript(  )
    KillUnit( GetUnitOfPlayer( 0, 0 ) )
    GameOver()
  )
)

Script Lever#0#1
(
  if
  (
    IsEqual( GetLeverState( GetObject( 1021001 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( GetObject( 5223993 ) , 1 )
  )
)

Script Lever#0#2
(
  if
  (
