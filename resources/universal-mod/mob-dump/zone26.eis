GlobalVars (
  NULL : object,
  VSS#i#val : object,
  i : object,
  Heroes : group
)

DeclareScript Start (  this : object )
DeclareScript CheckFail (  this : object )
DeclareScript EndOfGame (  this : object )
DeclareScript Lever#0#1 (  this : object )
DeclareScript Lever#0#2 (  this : object )
