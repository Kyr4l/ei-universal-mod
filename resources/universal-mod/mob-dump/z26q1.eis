Script PortalOn2
(
  if
  (
    IsEqual( GSGetVar( 0, "q.z26q1.z26q1.4" ) , 2 )
  )
  then
  (
    KillScript(  )
    CreateParticleSource( 1, 58.9, 161.8, 8.7, 0.7, "portalstar" )
    CreatePointLight( 1, 58.9, 161.8, 8.7, 5, 155, 155, 455 )
    CreateParticleSource( 2, 74.9, 161.8, 8.7, 0.7, "portalstar" )
    CreatePointLight( 2, 74.9, 161.8, 8.7, 5, 155, 155, 455 )
    CreateParticleSource( 3, 66.9, 169.8, 8.7, 0.7, "portalstar" )
    CreatePointLight( 3, 66.9, 169.8, 8.7, 5, 155, 155, 455 )
    CreateFXSource( -1, 67, 163, 6.1, 40, 70, "Tools\Teleport1.wav" ) 
    Sleep( 20 )
    CreateParticleSource( 4, 67, 163, 6.1, 1, "Portal" )
    CreatePointLight( 4, 67, 163, 6.7, 10, 155, 155, 455 )
    CreateFXSource( -1, 67, 163, 6.1, 40, 70, "Tools\Teleport2.wav" )
    CreateFXSource( -1, 67, 163, 6.1, 40, 70, "Tools\Teleport3.wav" )
  )
)

Script CheckAll
(
