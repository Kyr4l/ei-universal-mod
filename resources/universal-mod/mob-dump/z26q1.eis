  (
    IsEqual( GetLeverState( GetObject( 4309 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "q.z26q1.z26q1.3", 2 )
    GiveQuestItem( 0, "TeleportKey01" )
  )
)

