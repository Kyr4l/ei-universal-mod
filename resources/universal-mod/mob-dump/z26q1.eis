GlobalVars (
  NULL : object,
  VSS#i#val : object,
  i : object,
  Heroes : group
)

DeclareScript CheckGatesKey (  this : object )
DeclareScript CheckGates (  this : object )
DeclareScript PortalKey (  this : object )
DeclareScript PortalOn (  this : object )
DeclareScript PortalOn2 (  this : object )
DeclareScript CheckAll (  this : object )


Script CheckGatesKey
(
  if
  (
    IsEqual( GetLeverState( GetObject( 1021003 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "q.z26q1.z26q1.1", 2 )
  )
)

Script CheckGates
(
  if
  (
    IsEqual( GetLeverState( GetObject( 1021001 ) ) , 1 )
    IsEqual( GetLeverState( GetObject( 1021002 ) ) , 1 )
  )
  then
  (
    KillScript(  )
    GSSetVarMax( 0, "q.z26q1.z26q1.2", 2 )
  )
)

Script PortalKey
(
