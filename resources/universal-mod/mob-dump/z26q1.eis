    GSSetVarMax( 0, "q.z26q1.z26q1.4", 2 )
    GSSetVarMax( 0, "q.z26q1.z26q1", 2 )
    Sleep( 1 )
    QuestComplete( 0, "z26q1" )
  )
)


WorldScript
(
  Sleep( 2 )
  CheckGatesKey( NULL )
  CheckGates( NULL )
  PortalKey( NULL )
  PortalOn( NULL )
  PortalOn2( NULL )
  CheckAll( NULL )
)
