      CastSpellUnit( "eagle_sight", 0, 0, i )
    )
    ForIf( i, GetPlayerUnits( 4 ), IsAlive( i ) ) (
      CastSpellUnit( "eagle_sight", 0, 0, i )
    )
    Sleep( 5000 )
    #ESight(  )
  )
)

