Script #VCityGates#0#1
(
  if
  (
    Add( GSGetVar( 0, "q.z35q1.z35q1" ), Any( i, GetPlayerUnits( 0 ), IsLess( DistanceUnitUnit( i, this3 ), 7.5 ) ) )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, 1 )
  )
)

Script #VCityGates#0#2
(
  if
  (
    Not( GSGetVar( 0, "q.z35q1.z35q1" ) )
    Not( Any( i, GetPlayerUnits( 0 ), IsLess( DistanceUnitUnit( i, this3 ), 7.5 ) ) )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, 1 )
  )
)

