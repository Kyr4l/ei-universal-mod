  then
  (
    KillScript(  )
    GiveItem( 0, "platekey01" )
  )
)

Script #TPIn
(
  if
  (
    IsEqual( GetLeverState( TPlateLever ), 1 )
  )
  then
  (
    KillScript(  ) 
    ForIf( k, Heroes, IsLess( DistanceUnitUnit( k, OutBP ), 1.5 ) ) (
      SetCP( k, GetX( InBP ), GetY( InBP ), 0 )
    )
    Sleep( 150 )
    Sleep( 75 )
    #TPIn(  )
  )
)

Script #TPOut
(
  if
  (
    IsEqual( GetLeverState( TPlateLever ), 1 )
  )
  then
  (
    KillScript(  ) 
    Sleep( 75 )
    ForIf( k, Heroes, IsLess( DistanceUnitUnit( k, InBP ), 1.5 ) ) (
      SetCP( k, GetX( OutBP ), GetY( OutBP ), 0 )
    )
    Sleep( 150 )
    #TPOut(  )
  )
)

