Script #Start#0
(
  if
  (
  )
  then
  (
    KillScript(  )
    AddMob( "Autogz5jgoodtown.mob" )
    Sleep( 5 ) 
  )
)

Script #Dialog#0
(
  if
  (
    Not( IsEqual( GSGetVar( 0, dialog ), 1 ) )
  )
  then
  (
    KillScript(  )
    GSSetVar( 0, dialog, 1 )
  )
)

Script #CycleLever#0
(
  if
  (
    Not( IsEqual( GetLeverState( this ), state ) )
  )
  then
  (
    KillScript(  )
    Sleep( 45 )
    EnableLever( this, 1 )
    #CycleLever#0( this, GetLeverState( this ) )
  )
)

Script #CycleLever#1
(
  if
  (
    IsEqual( GetLeverState( this1 ), GSGetVar( 0, gate ) )
    Not( IsEqual( GetLeverState( this1 ), state ) )
    IsEqual( GetLeverState( this1 ), 1 )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, Not( GetLeverState( this2 ) ) )
    //ConsoleString( "g____0" )
    //ConsoleFloat( GetX( this1 ) )
    //ConsoleFloat( GetY( this1 ) )
    Sleep( 45 )
    EnableLever( this1, 1 )
    #CycleLever#1( this1, this2, GetLeverState( this1 ), gate )
  )
  if
  (
    IsEqual( GetLeverState( this1 ), GSGetVar( 0, gate ) )
    Not( IsEqual( GetLeverState( this1 ), state ) )
    IsEqual( GetLeverState( this1 ), 0 )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, Not( GetLeverState( this2 ) ) )
    //ConsoleString( "g____1" )
    //ConsoleFloat( GetX( this1 ) )
    //ConsoleFloat( GetY( this1 ) )
    Sleep( 45 )
    EnableLever( this1, 1 )
    #CycleLever#1( this1, this2, GetLeverState( this1 ), gate )
  )
  if
  (
    Not( IsEqual( GetLeverState( this1 ), GSGetVar( 0, gate ) ) )
    Not( IsEqual( GetLeverState( this1 ), state ) )
    IsEqual( GetLeverState( this1 ), 1 )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, Not( GetLeverState( this2 ) ) )
    //CastSpellPoint( "fireworks{a4;a4;a4;a4;a4;a4;a4;a4}", GetX( this1 ), GetY( this1 ), GetX( this1 ), GetY( this1 ), GetUnitOfPlayer( 0, 0 ) )
    //ConsoleString( "g____2" )
    //ConsoleFloat( GetX( this1 ) )
    //ConsoleFloat( GetY( this1 ) )
    Sleep( 45 )
    EnableLever( this1, 1 )
    #CycleLever#1( this1, this2, GetLeverState( this1 ), gate )
  )
  if
  (
    Not( IsEqual( GetLeverState( this1 ), GSGetVar( 0, gate ) ) )
    Not( IsEqual( GetLeverState( this1 ), state ) )
    IsEqual( GetLeverState( this1 ), 0 )
  )
  then
  (
    KillScript(  )
    SwitchLeverState( this2, Not( GetLeverState( this2 ) ) )
    //CastSpellPoint( "fireworks{a4;a4;a4;a4;a4;a4;a4;a4}", GetX( this1 ), GetY( this1 ), GetX( this1 ), GetY( this1 ), GetUnitOfPlayer( 0, 0 ) )
    //ConsoleString( "g____3" )
    //ConsoleFloat( GetX( this1 ) )
    //ConsoleFloat( GetY( this1 ) )
    Sleep( 45 )
    EnableLever( this1, 1 )
    #CycleLever#1( this1, this2, GetLeverState( this1 ), gate )
  )
)

Script #VFire#0#1
(
  if
  (
    IsGreater( GetWorldTime( ) , 20 )
  )
  then
  (
    KillScript(  )
    #VFireCity#0#1( this )
    #VFire#1#1( this )
  )
)

Script #VFire#1#1
(
  if
  ( 
    IsLess( GetWorldTime( ) , 5 )
  )
  then
  (
    KillScript(  )
    Sleep( 30 )
    #VFire#0#1( this ) 
  )
)

Script #VFire#0#2
(
  if
  ( 
    IsLess( GetWorldTime( ) , 5 )
  )
  then
  (
    KillScript(  )
    #VFireCity#0#2( this )
  )
)

Script #VFire#0#3
(
  if
  ( 
    IsGreater( GetWorldTime( ) , 5 ) 
    IsLess( GetWorldTime( ) , 6 )
  )
  then
  (
    KillScript(  )
    #VFireCity#0#3( this )
    #VFire#1#3( this )
  )
)

Script #VFire#1#3
(
  if
  (
    IsGreater( GetWorldTime( ) , 6 ) 
    IsLess( GetWorldTime( ) , 19.9 )
  )
  then
  (
    KillScript(  )
    Sleep( 30 )
    #VFire#0#3( this ) 
  )
)

